# ==========================================
# Build / Distribution Artifacts
# ==========================================
# frontend/dist is FULLY excluded:
# - It is built on the live server via CI/CD or manually.
# - Committing it overwrites live server branding assets (logo, favicon, PWA icons).
# - Any git pull would reset the live server's customised assets.
frontend/dist/
dist.tar.gz
dist-ssr/
stats.html
public/build/
public/hot/
public/js/chunk-*
public/css/chunk-*

# ==========================================
# Live Server Branding Assets (backend/public)
# ==========================================
# These are uploaded/customised directly on the live server.
# Tracking them means every git push resets the live branding.
backend/public/favicon.ico

# ==========================================
# Laravel / Backend Output & Cache
# ==========================================
.phpunit.result.cache
.phpunit.cache
.phpactor.json
public/storage/
backend/public/storage
backend/storage/*.key
backend/storage/pail/

# Protect Framework Cache & Sessions from git clean
backend/storage/framework/cache/*
!backend/storage/framework/cache/.gitignore
backend/storage/framework/cache/data/*
!backend/storage/framework/cache/data/.gitignore
backend/storage/framework/sessions/*
!backend/storage/framework/sessions/.gitignore
backend/storage/framework/views/*
!backend/storage/framework/views/.gitignore
backend/storage/framework/testing/*
!backend/storage/framework/testing/.gitignore

# Protect Logs from git clean
backend/storage/logs/*
!backend/storage/logs/.gitignore

# Protect Bootstrap Cache from git clean
backend/bootstrap/cache/*
!backend/bootstrap/cache/.gitignore

# ==========================================
# Live Server Upload Directories
# ==========================================
# ALL user-uploaded and server-side generated files are excluded.
# Git MUST NEVER touch these — a pull would wipe live lead documents,
# branding assets, offer images, receipts, profiles and survey photos.
backend/storage/app/public/branding/
backend/storage/app/public/homepage/
backend/storage/app/public/profiles/
backend/storage/app/public/offer_images/
backend/storage/app/public/achievements/
backend/storage/app/public/admin_receipts/
backend/storage/app/public/ledger_receipts/
backend/storage/app/public/survey_photos/
backend/storage/app/public/leads/
backend/storage/app/leads/
backend/storage/app/private/

Homestead.json
Homestead.yaml
**/caddy
